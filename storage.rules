// storage.rules
// Deploy with: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Public photos
    match /photos/{allPaths=**} {
      allow read: if true;
      allow write: if true;   // Restrict to authenticated users in production
    }

    // Private photos
    match /private_photos/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // Audio files
    match /audio/{allPaths=**} {
      allow read: if true;
      allow write: if true;   // Restrict to admin in production
    }
  }
}
